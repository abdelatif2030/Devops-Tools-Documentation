pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub')
        IMAGE_NAME = "abdo1997mohamed2030/comingsoon-page:latest"
        APP_DIR = "DevOps-Pipeline-PHP/laravel-app"
    }

    parameters {
        booleanParam(name: 'SKIP_BUILD', defaultValue: true, description: 'Skip Docker image build')
    }

    stages {
        stage('Docker Login') {
            steps {
                sh """
                    echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin
                """
            }
        }

        stage('Pull Docker Image') {
            when {
                expression { return params.SKIP_BUILD }
            }
            steps {
                sh "docker pull ${IMAGE_NAME}"
            }
        }

        stage('Run Docker Compose') {
            steps {
                dir("${APP_DIR}") {
                    sh "docker-compose up -d"
                }
            }
        }
    }

    post {
        always {
            echo "Cleaning up dangling images..."
            sh "docker image prune -f"
        }
    }
}