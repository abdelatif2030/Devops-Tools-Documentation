pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub') // username/password binding
        IMAGE_NAME = "abdo1997mohamed2030/comingsoon-page:latest"
        APP_DIR = "DevOps-Pipeline-PHP/laravel-app"
    }

    parameters {
        booleanParam(name: 'SKIP_BUILD', defaultValue: true, description: 'Skip Docker image build')
    }

    stages {
        stage('Docker Login') {
            steps {
                sh '''
                    echo "$DOCKERHUB_CREDENTIALS_PSW" | docker login -u "$DOCKERHUB_CREDENTIALS_USR" --password-stdin
                '''
            }
        }

        stage('Pull or Build Docker Image') {
            steps {
                script {
                    if (params.SKIP_BUILD) {
                        echo "Pulling image from DockerHub..."
                        sh "docker pull ${IMAGE_NAME}"
                    } else {
                        echo "Building Docker image..."
                        dir("${APP_DIR}") {
                            sh "docker build -t ${IMAGE_NAME} ."
                        }
                        echo "Pushing image to DockerHub..."
                        sh "docker push ${IMAGE_NAME}"
                    }
                }
            }
        }

        stage('Run Docker Compose') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        docker compose down || true
                        docker compose up -d
                    '''
                }
            }
        }

        stage('Verify Running Containers') {
            steps {
                sh '''
                    echo "Running containers:"
                    docker ps
                '''
            }
        }
    }

    post {
        always {
            echo "Cleaning up dangling images..."
            sh 'docker image prune -f'
        }
        success {
            echo 'Deployment completed successfully!'
        }
        failure {
            echo 'Deployment failed. Check the logs above.'
        }
    }
}