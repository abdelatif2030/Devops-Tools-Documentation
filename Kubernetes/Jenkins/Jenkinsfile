pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub')
    }

    stages {
        stage('Docker Login') {
            steps {
                script {
                    retry(3) {
                        def status = sh(
                            script: 'echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin',
                            returnStatus: true
                        )
                        if (status != 0) {
                            echo "Docker login failed, retrying..."
                            sleep 10
                            error("Docker login failed")
                        }
                    }
                }
            }
        }

        stage('Build & Push Docker Image') {
            steps {
                sh '''
                cd Kubernetes/comingsoon/
                ansible-playbook playbook.yml
                '''
            }
        }

        stage('Delete Existing Cluster') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: "aws-credentials",
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh '''
                    echo "Deleting old cluster if exists..."
                    eksctl delete cluster --name comingsoon-cluster --region eu-north-1 || true
                    sleep 60
                    '''
                }
            }
        }

        stage('Create Cluster (t3.micro Free Tier)') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: "aws-credentials",
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh '''
                    eksctl create cluster \
                        --name comingsoon-cluster \
                        --region eu-north-1 \
                        --nodes-min=1 \
                        --nodes-max=1 \
                        --node-type t3.micro \
                        --timeout 30m || true

                    aws eks update-kubeconfig --name comingsoon-cluster
                    '''
                }
            }
        }

        stage('Create Namespace') {
            steps {
                sh 'kubectl create namespace comingsoon || true'
            }
        }

        stage('Deploy Application') {
            steps {
                sh '''
                cd Kubernetes/comingsoon/k8s
                kubectl -n comingsoon apply -f deployment.yaml
                kubectl -n comingsoon apply -f services.yaml
                '''
            }
        }
    }

    post {
        always {
            echo "Pipeline finished. Check logs for errors."
        }
        failure {
            echo "Pipeline failed! Cleaning up cluster..."
            withCredentials([[
                $class: 'AmazonWebServicesCredentialsBinding',
                credentialsId: "aws-credentials",
                accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
            ]]) {
                sh 'eksctl delete cluster --name comingsoon-cluster --region eu-north-1 || true'
            }
        }
    }
}